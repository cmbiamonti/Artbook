{
  "compilerOptions": {
    "outDir": "./dist-electron",
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": false,
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "removeComments": false,
    "isolatedModules": false
  },
  "include": ["electron/**/*"],
  "exclude": ["node_modules", "dist", "dist-electron", "src"]
}