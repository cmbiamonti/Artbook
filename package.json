{
  "name": "artbook",
  "version": "1.0.0",
  "description": "ArtBook — Catalogo digitale per collezioni d'arte",
  "author": {
    "name": "La Stanza dell'Arte",
    "email": "info@lastanzadellarte.com",
    "url":   "https://lastanzadellarte.com"
  },
  "license": "UNLICENSED",
  "main": "dist-electron/main.js",
  "type": "commonjs",
 "scripts": {
    "dev":                "vite",
    "build":              "tsc && vite build",
    "electron:dev":       "electron .",
    "electron:build":     "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.17.0",
    "i18next": "^26.0.1",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.0",
    "react-i18next": "^17.0.1",
    "react-router-dom": "^6.20.0",
    "sonner": "^1.3.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/sql.js": "^1.4.10",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.27",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "fs-extra": "^11.3.4",
    "postcss": "^8.5.8",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId":       "com.lastanzadellarte.artbook",
    "productName": "ArtBook",
    "copyright":   "© 2025 La Stanza dell'Arte",
    "asar":        true,

    "directories": {
      "buildResources": "build",
      "output":         "release"
    },

    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],

    "mac": {
      "appId":              "com.lastanzadellarte.artbook",
      "category":           "public.app-category.productivity",
      "icon":               "build/icons/icon.icns",
      "darkModeSupport":    true,
      "hardenedRuntime":    true,
      "gatekeeperAssess":   false,
      "entitlements":       "build/entitlements.mac.plist",
      "entitlementsInherit":"build/entitlements.mac.plist",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },

    "dmg": {
      "title":  "${productName} ${version}",
      "window": { "width": 540, "height": 380 },
      "contents": [
        { "x": 150, "y": 185, "type": "file"                          },
        { "x": 390, "y": 185, "type": "link", "path": "/Applications" }
      ]
    },

    "win": {
      "icon":   "build/icons/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },

    "nsis": {
      "oneClick":    false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut":              true,
      "createStartMenuShortcut":            true,
      "installerIcon":   "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico"
    },

    "linux": {
      "icon":     "build/icons",
      "target":   ["AppImage", "deb"],
      "category": "Office"
    }
  }
}